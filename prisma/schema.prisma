// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ──────────────────────────────────────────────
// Auth / User
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts    Account[]
  sessions    Session[]
  reviews     Review[]
  favorites   Favorite[]
  itineraries Itinerary[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// Content
// ──────────────────────────────────────────────

model City {
  id        String   @id @default(cuid())
  slug      String   @unique
  nameEn    String
  nameZh    String
  nameJa    String?
  nameKo    String?
  nameFr    String?
  descEn    String   @db.Text
  descZh    String   @db.Text
  descJa    String?  @db.Text
  descKo    String?  @db.Text
  descFr    String?  @db.Text
  heroImage String
  lat       Float
  lng       Float
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attractions Attraction[]
  foods       Food[]
  itineraries Itinerary[]
}

model Attraction {
  id        String             @id @default(cuid())
  slug      String             @unique
  cityId    String
  nameEn    String
  nameZh    String
  nameJa    String?
  nameKo    String?
  nameFr    String?
  descEn    String             @db.Text
  descZh    String             @db.Text
  descJa    String?            @db.Text
  descKo    String?            @db.Text
  descFr    String?            @db.Text
  category  AttractionCategory
  images    String             @db.Text
  lat       Float?
  lng       Float?
  rating    Float              @default(0)
  published Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  city      City       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  reviews   Review[]
  favorites Favorite[]
}

model Food {
  id         String       @id @default(cuid())
  slug       String       @unique
  cityId     String
  nameEn     String
  nameZh     String
  nameJa     String?
  nameKo     String?
  nameFr     String?
  descEn     String       @db.Text
  descZh     String       @db.Text
  descJa     String?      @db.Text
  descKo     String?      @db.Text
  descFr     String?      @db.Text
  category   FoodCategory
  images     String       @db.Text
  spiceLevel Int          @default(0)
  priceRange PriceRange   @default(MEDIUM)
  published  Boolean      @default(true)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  city      City       @relation(fields: [cityId], references: [id], onDelete: Cascade)
  reviews   Review[]
  favorites Favorite[]
}

model Review {
  id           String     @id @default(cuid())
  userId       String
  targetType   TargetType
  attractionId String?
  foodId       String?
  rating       Int
  content      String     @db.Text
  published    Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  attraction Attraction? @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  food       Food?       @relation(fields: [foodId], references: [id], onDelete: Cascade)
}

model Favorite {
  id           String     @id @default(cuid())
  userId       String
  targetType   TargetType
  attractionId String?
  foodId       String?
  createdAt    DateTime   @default(now())

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  attraction Attraction? @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  food       Food?       @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@unique([userId, targetType, attractionId])
  @@unique([userId, targetType, foodId])
}

model Itinerary {
  id        String   @id @default(cuid())
  userId    String
  cityId    String
  title     String
  days      Int      @default(3)
  isPublic  Boolean  @default(false)
  shareSlug String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  city  City            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  items ItineraryItem[]
}

model ItineraryItem {
  id           String     @id @default(cuid())
  itineraryId  String
  day          Int
  order        Int
  targetType   TargetType
  attractionId String?
  foodId       String?
  note         String?    @db.Text

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
}

model TravelTip {
  id        String      @id @default(cuid())
  category  TipCategory
  titleEn   String
  titleZh   String
  titleJa   String?
  titleKo   String?
  titleFr   String?
  contentEn String      @db.Text
  contentZh String      @db.Text
  contentJa String?     @db.Text
  contentKo String?     @db.Text
  contentFr String?     @db.Text
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ──────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum TargetType {
  ATTRACTION
  FOOD
}

enum AttractionCategory {
  HISTORICAL
  NATURAL
  CULTURAL
  MODERN
  RELIGIOUS
  ENTERTAINMENT
  SHOPPING
}

enum FoodCategory {
  NOODLES
  DUMPLINGS
  HOTPOT
  STREET_FOOD
  DESSERT
  SEAFOOD
  ROASTED
  VEGETARIAN
  DIM_SUM
  SOUP
}

enum PriceRange {
  BUDGET
  MEDIUM
  UPSCALE
}

enum TipCategory {
  VISA
  TRANSPORT
  PAYMENT
  APPS
  LANGUAGE
  SAFETY
  HEALTH
  ETIQUETTE
}
